{
  "expo": {
    "name": "Metro Routes",
    "slug": "DelhiMetroApp",
    "scheme": "com.siddharth.dmrc",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/new-icon.png",
    "userInterfaceStyle": "light",
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.siddharth.dmrc"
    },
    "android": {
      "package": "com.siddharth.dmrc",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/new-icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "d5a9f98e-de44-445e-a448-a26619eb91e6"
      }
    },
    "owner": "siddharth-28",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/d5a9f98e-de44-445e-a448-a26619eb91e6"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true
          }
        }
      ],
      "./withAndroidArchitectures.js",
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "siddharth-4t"
        }
      ],
      "expo-font",
      "@sentry/react-native"
    ],
    "splash": {
      "image": "./assets/new-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D0D"
    }
  }
}
